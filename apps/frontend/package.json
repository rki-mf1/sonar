{
  "name": "sonar-frontend",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "format": "prettier --write '**/*.{js,ts,vue,json}'",
    "format-check": "prettier --check '**/*.{js,ts,vue,json}'",
    "lint": "eslint src",
    "build-only": "vite build",
    "build:backend-proxy": "npm run build && mkdir -p ../backend/work/frontend/dist && cp -r dist/. ../backend/work/frontend/dist/",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-moment": "^1.0.1",
    "chartjs-plugin-zoom": "^2.0.1",
    "chroma-js": "^3.2.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "oh-vue-icons": "^1.0.0-rc3",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "qs": "^6.15.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/chroma-js": "^3.1.2",
    "@types/exceljs": "^1.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.0.1",
    "@types/qs": "^6.15.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vue-tsc": "^3.3.6"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  }
}
