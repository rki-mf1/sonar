# sonar-cli configuration reference
#
# Copy this file to:
#   ${XDG_CONFIG_HOME:-$HOME/.config}/sonar-cli/sonar-cli.config
#
# All settings are optional. The CLI uses these same values internally as its
# built-in defaults, so you can run without a config file if they already suit
# your environment.
#
# Precedence:
# 1. Explicit command-line option such as --db
# 2. Environment variable
# 3. XDG config file
# 4. Built-in default shown below

# Backend API URL.
# Local contributor dev stack: http://127.0.0.1:9080/api
# Proxy-based or deployed setups may use a different host/port.
# API_URL=http://127.0.0.1:9080/api

# Optional client-side secret key used by parts of the CLI that expect one.
# SECRET_KEY=development-secret

# Logging level.
# Accepted values include DEBUG, INFO, WARNING, ERROR, CRITICAL.
# LOG_LEVEL=INFO

# Max seqhash batch size for duplicate checks during import.
# CHUNK_SIZE=10000

# Samples per annotation worker chunk.
# Also controls how many sample/variant bundles are grouped per archive step.
# ANNO_CHUNK_SIZE=250

# Metadata import chunk size.
# PROP_CHUNK_SIZE=1000

# Parallel import/cache tuning.
# PARANOID_CHUNK_SIZE=50
# PARANOID_N_JOBS=8
# CACHE_CLEAR_CHUNK_SIZE=250
# CACHE_CLEAR_N_JOBS=4

# Skip samples with deletions longer than this many base pairs.
# FILTER_DELETE_SIZE=2000

# Page size for paginated match queries.
# MATCH_CHUNK_LIMIT=300

# Annotation tool configuration.
# ANNO_TOOL_PATH=snpEff
# Leave empty to let sonar-cli auto-discover snpEff.config.
# ANNO_CONFIG_FILE=

# Sourmash settings.
# KSIZE=11
# SCALED=1
